{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "backgroundColor": "#00000000",
        "decorations": false,
        "height": 700,
        "resizable": false,
        "scrollBarStyle": "fluentOverlay",
        "shadow": false,
        "theme": "Dark",
        "title": "NHF Addon Manager",
        "transparent": true,
        "width": 800
      }
    ]
  },
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "deno task dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../build"
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all"
  },
  "identifier": "com.nhf-aura-manager.app",
  "plugins": {
    "updater": {
      "endpoints": [
        "https://nhfguild.com/api/external/v1/releases/client/update/{{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI2MTI1MjkzNTdGRjYxNQpSV1FWOW44MUtTVmhBdm1ROWx5eGc2aFd4OVpBTUFsNkxRajJtYTZKMWlOVnQ5N0VNbXplY2ZpLwo=",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "productName": "NHF Addon Manager",
  "version": "0.5.6"
}

# Copy to `.env` and fill in values for local development.
# SvelteKit only exposes variables prefixed with PUBLIC_ to the frontend.

# NHF backend API (no trailing slash).
# Used for addon/client release metadata, companion data, and version checks.
# Also baked into the Tauri updater endpoint at build time (via build.rs).
#
# Examples:
#   PUBLIC_EXTERNAL_API_HOST=https://nhfguild.com
#   PUBLIC_EXTERNAL_API_HOST=http://localhost:5000
PUBLIC_EXTERNAL_API_HOST=https://your-nhf-backend.example.com

# --- Optional: only needed to build signed app updates (CI / release builds) ---

# Tauri updater signing key (base64-encoded private key from `tauri signer generate`).
# TAURI_SIGNING_PRIVATE_KEY=

# Password for the signing key, if one was set during key generation.
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
